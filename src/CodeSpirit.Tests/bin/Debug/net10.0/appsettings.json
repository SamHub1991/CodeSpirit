{
  "CodeSpirit": {
    "Name": "CodeSpirit Demo",
    "Version": "1.0.0",
    "Profile": "development"
  },
  "Jwt": {
    "Secret": "CodeSpirit-Dev-SuperSecret-Key-That-Is-At-Least-32-Characters-Long!",
    "Issuer": "CodeSpirit",
    "Audience": "CodeSpirit-Client",
    "ExpirationMinutes": 60
  },
  "Redis": {
    "ConnectionString": ""
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest"
  },
  "Telemetry": {
    "ServiceName": "CodeSpirit",
    "ServiceVersion": "1.0",
    "EnableConsoleExporter": true,
    "EnableTracing": true,
    "EnableMetrics": true
  },
  "Database": {
    "Provider": "Sqlite",
    "Name": "codespirit.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CodeSpirit": "Debug"
    }
  },
  "AllowedHosts": "*"
}
