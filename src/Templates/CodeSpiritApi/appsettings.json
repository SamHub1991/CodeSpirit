{
  "CodeSpirit": {
    "Name": "CodeSpiritApi",
    "Version": "1.0.0",
    "Profile": "development",
    "Actuator": {
      "EnableHealthEndpoint": true,
      "EnableMetricsEndpoint": true,
      "EnableInfoEndpoint": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CodeSpirit": "Debug"
    }
  },
  "AllowedHosts": "*"
}
