{
  "$schema": "http://json.schemastore.org/template",
  "author": "CodeSpirit",
  "classifications": ["Web", "API", "CodeSpirit"],
  "name": "CodeSpirit API Application",
  "description": "A .NET 10 CodeSpirit framework API application with MVVM, scheduling, and auto-configuration.",
  "identity": "CodeSpirit.Api.Template",
  "groupIdentity": "CodeSpirit.Api",
  "shortName": "codespirit-api",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "CodeSpiritApi",
  "preferNameDirectory": true,
  "primaryOutputs": [
    { "path": "CodeSpiritApi.csproj" }
  ],
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        { "choice": "net10.0", "description": "Target net10.0" },
        { "choice": "net9.0", "description": "Target net9.0" }
      ],
      "defaultValue": "net10.0",
      "replaces": "net10.0"
    },
    "SkipRestore": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "If specified, skips the automatic restore of the project on create."
    }
  },
  "postActions": [
    {
      "condition": "(!SkipRestore)",
      "description": "Restore NuGet packages required by this project.",
      "manualInstructions": [
        { "text": "Run 'dotnet restore'" }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
