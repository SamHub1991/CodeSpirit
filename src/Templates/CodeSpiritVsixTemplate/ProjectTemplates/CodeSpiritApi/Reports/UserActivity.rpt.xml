<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="urn:codespirit:report"
        Title="User Activity Report"
        Orientation="Landscape"
        PageSize="A4">

  <ReportHeader>
    <Text Style="Title" Alignment="Center">
      User Activity Report
    </Text>
    <Text Style="Subtitle" Alignment="Center">
      {Binding Period}
    </Text>
  </ReportHeader>

  <Body>
    <Table DataSource="{Binding Activities}">
      <Columns>
        <Column Header="User" Field="UserName" Width="20%" />
        <Column Header="Action" Field="Action" Width="30%" />
        <Column Header="Module" Field="Module" Width="20%" />
        <Column Header="Timestamp" Field="Timestamp" Width="30%" Format="yyyy-MM-dd HH:mm:ss" />
      </Columns>
    </Table>
  </Body>
</Report>